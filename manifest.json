{
  "manifest_version": 3,
  "name": "Workday AI Autofiller",
  "version": "1.0.0",
  "description": "AI-Powered Chrome Extension for automating Workday job applications",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Workday AI Autofiller"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.myworkdayjobs.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://*.myworkdayjobs.com/*",
    "https://api.openai.com/*"
  ]
}
